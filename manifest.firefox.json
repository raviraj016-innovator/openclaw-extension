{
  "manifest_version": 2,
  "name": "OpenClaw Context Bridge",
  "version": "0.1.0",
  "description": "Ambient browser context streaming for OpenClaw AI agents",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "contextMenus",
    "webNavigation",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background/service-worker.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "sidebar_action": {
    "default_panel": "sidepanel/sidepanel.html",
    "default_title": "OpenClaw",
    "default_icon": "icons/icon-48.png"
  },
  "commands": {
    "send-highlight": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Send highlighted text to OpenClaw"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "incognito": "not_allowed",
  "browser_specific_settings": {
    "gecko": {
      "id": "openclaw-extension@openclaw.ai",
      "strict_min_version": "109.0"
    }
  }
}
