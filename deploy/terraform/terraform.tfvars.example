# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git

region            = "us-east-1"
domain            = "context.yourdomain.com"
anthropic_api_key = "sk-ant-..."
instance_type     = "t3.medium"
volume_size       = 30
github_repo       = "YOUR_USERNAME/openclaw-extension"

# Optional: provide your own extension token (or leave empty to auto-generate)
# extension_token = "your-custom-token"

# Optional: restrict SSH to your IP
# ssh_allowed_cidrs = ["1.2.3.4/32"]
